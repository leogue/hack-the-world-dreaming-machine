#!/usr/bin/env bash
# GPU allocation and memory per node in defq
# Usage: gpus

B='\033[1m' G='\033[0;32m' Y='\033[1;33m' R='\033[0;31m' N='\033[0m'

echo -e "${B}=== GPU nodes — defq ===${N}"
printf "${B}%-14s %5s %5s %5s %-10s %8s %8s${N}\n" \
  "NODE" "TOT" "USED" "FREE" "STATE" "CPU_LOAD" "FREE_MEM"

sinfo -p defq -N \
  --Format="NodeHost:14,Gres:30,GresUsed:30,StateLong:10,CPUsLoad:10,FreeMem:10" \
  --noheader | \
awk -v G="$G" -v Y="$Y" -v R="$R" -v N="$N" '
{
  node=$1; gres=$2; gused=$3; state=$4; load=$5; freemb=$6
  match(gres,  /gpu:[^:]+:([0-9]+)/, a); total=a[1]+0
  match(gused, /gpu:[^:]+:([0-9]+)/, b); used=b[1]+0
  free=total-used
  freegb=int(freemb/1024)
  color = (free==total) ? G : (free==0) ? R : Y
  printf color "%-14s %5d %5d %5d %-10s %8s %6dGB\n" N, node, total, used, free, state, load, freegb
}'

echo ""
echo -e "${B}Totals:${N}"
sinfo -p defq -N --Format="Gres:30,GresUsed:30,StateLong:10" --noheader | \
awk '
{
  match($1, /gpu:[^:]+:([0-9]+)/, a); total+=a[1]+0
  match($2, /gpu:[^:]+:([0-9]+)/, b); used+=b[1]+0
}
END { printf "  GPUs: %d used / %d total (%d free)\n", used, total, total-used }'
