#!/usr/bin/env bash
# My SLURM jobs — color-coded by state
# Usage: sq

G='\033[0;32m' Y='\033[1;33m' R='\033[0;31m' B='\033[1m' N='\033[0m'

squeue -u "$USER" --sort=-T,i \
  --Format="JobID:10,Name:30,State:12,TimeUsed:12,TimeLeft:12,NumNodes:5,NumCPUs:5,tres-alloc:22,Reason" | \
awk -v G="$G" -v Y="$Y" -v R="$R" -v B="$B" -v N="$N" '
  NR==1 { print B $0 N; next }
  /RUNNING/            { print G $0 N; next }
  /PENDING/            { print Y $0 N; next }
  /FAILED|CANCEL|TIME/ { print R $0 N; next }
  { print }
'
echo ""
squeue -u "$USER" --noheader --Format="State" | sort | uniq -c | \
  awk '{printf "  %s: %d\n", $2, $1}'
